# ===================================================
# Re:Seat KBO Scraper — .gitignore
# ===================================================

# 1. Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# 2. IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# 3. OS
.DS_Store
Thumbs.db
$RECYCLE.BIN/

# 4. 환경 변수 & 시크릿
.env
.env.*
!.env.example
application-local.yml
application-secret.yml

# 5. 로그
*.log
logs/

# 6. Playwright 브라우저 캐시
.playwright/

# 7. 컴파일 산출물
*.class
*.jar
*.war

# 8. JVM crash
hs_err_pid*
replay_pid*

# 9. 스크래퍼 산출물 — CSV는 output/ 폴더로 나옴
# CSV는 커밋 대상이 아님 (본체 레포로 옮겨서 커밋)
output/